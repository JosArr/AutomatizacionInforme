# VARIABLES DE ENTORNO PARA CREDENCIALES SQL SERVER
#
# Nunca committear archivos .env con contraseñas a git
# Este archivo es solo un ejemplo
#
# Copiar este archivo a .env y llenar con tus credenciales reales

# Formato de variable:
# SQLSERVER_{SERVIDOR}_{INSTANCIA}_PASSWORD=contraseña
# o
# SQLSERVER_{SERVIDOR}_PASSWORD=contraseña (sin instancia)

# Ejemplos:

# Servidor 172.16.4.166 con instancia SACVDB
SQLSERVER_172.16.4.166_SACVDB_PASSWORD=tu_password_aqui

# Servidor 172.25.91.69 (sin instancia específica)
SQLSERVER_172.25.91.69_PASSWORD=otro_password_aqui

# Si usas domain\user, también puedes especificar el usuario
# SQLSERVER_SQL_PROD_USER=DOMINIO\usuario
# SQLSERVER_SQL_PROD_PASSWORD=password

# Para desarrollo local, puedes usar Windows Auth integrada
# En ese caso, no necesitas especificar password

# Ejemplo con nombre de servidor largo:
# SQLSERVER_PROD_DB_172_16_4_166_MSSQLSERVER_PASSWORD=contraseña

# NOTAS DE SEGURIDAD:
# 1. Este archivo NUNCA debe committearse a control de versiones
# 2. Añadir .env a .gitignore
# 3. Usar en CI/CD: secrets en GitHub Actions, Azure DevOps, etc.
# 4. En producción: considerar Azure KeyVault o similares
# 5. Rotación regular de passwords
# 6. Logs NUNCA mostrarán passwords

# Para usar este archivo:
# 1. Copiar a .env (sin .example)
# 2. Llenar con tus contraseñas reales
# 3. El programa las cargará automáticamente

# Ejemplo Python para cargar:
# from dotenv import load_dotenv
# import os
# load_dotenv('.env')
# password = os.getenv('SQLSERVER_172_16_4_166_PASSWORD')

